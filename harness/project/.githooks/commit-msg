#!/usr/bin/env bash
# commit-msg — Enforce Conventional Commits on the subject line.
#
# Installed via:  bash scripts/install-git-hooks.sh  (or `make install-git-hooks`)
# Bypass (humans, intentional only):  git commit --no-verify

set -uo pipefail

msg_file="${1:-}"
[[ -z "$msg_file" || ! -f "$msg_file" ]] && exit 0

subject="$(head -n1 "$msg_file")"

# Allow auto-generated commits with fixed prefixes
case "$subject" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*|"amend! "*) exit 0 ;;
esac

# Conventional Commits: <type>(<scope>)!?: <subject>
pattern='^(feat|fix|docs|refactor|test|chore|perf|ci|build|style|revert)(\([^)]+\))?!?: .+'

if [[ ! "$subject" =~ $pattern ]]; then
  cat >&2 <<EOF
[commit-msg] subject does not match Conventional Commits:
  $subject

required: <type>(<scope>)!?: <description>
  type  = feat | fix | docs | refactor | test | chore | perf | ci | build | style | revert
  scope = optional, in parens (e.g. api, web, shared)
  !     = optional, indicates a BREAKING change (also add 'BREAKING CHANGE:' line in body)

examples:
  feat(api): add user search endpoint
  fix(web)!: drop legacy auth flow
  docs: update README

bypass (humans, intentional only):  git commit --no-verify
EOF
  exit 1
fi

if (( ${#subject} > 70 )); then
  echo "[commit-msg] WARN: subject is ${#subject} chars (recommended <= 70)" >&2
fi

exit 0
