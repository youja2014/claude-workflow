APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/__package__
API_PREFIX=/api

# CORS — comma-separated origins (empty = disabled)
CORS_ORIGINS=http://localhost:5173

# Observability (all optional — empty values disable each integration)
OTEL_SERVICE_NAME=__package__
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
