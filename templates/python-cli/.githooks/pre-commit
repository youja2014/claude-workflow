#!/usr/bin/env bash
# pre-commit — Format & lint staged Python files + light safety checks.
#
# Installed via:  bash scripts/install-git-hooks.sh  (or `make install-git-hooks`)
# Bypass (humans, intentional only):  git commit --no-verify

set -uo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)

if [[ -n "$staged" ]]; then
  echo "[pre-commit] ruff format..."
  echo "$staged" | xargs --no-run-if-empty uv run ruff format \
    || { echo "[pre-commit] ruff format failed" >&2; exit 1; }

  echo "[pre-commit] ruff check --fix..."
  echo "$staged" | xargs --no-run-if-empty uv run ruff check --fix \
    || { echo "[pre-commit] ruff check found unfixable issues" >&2; exit 1; }

  # Re-stage auto-fixed
  echo "$staged" | xargs --no-run-if-empty git add

  echo "[pre-commit] pyright..."
  echo "$staged" | xargs --no-run-if-empty uv run pyright \
    || { echo "[pre-commit] pyright found issues" >&2; exit 1; }
fi

# Light safety checks (cheap, always run on staged content)
all_staged=$(git diff --cached --name-only --diff-filter=ACM)
if [[ -n "$all_staged" ]]; then
  if git diff --cached -U0 | grep -Eq '^\+(<{7}|={7}|>{7}) '; then
    echo "[pre-commit] merge conflict markers in staged content" >&2; exit 1
  fi
  if git diff --cached -U0 | grep -Eq '(BEGIN RSA PRIVATE|BEGIN OPENSSH PRIVATE|BEGIN PGP PRIVATE|BEGIN DSA PRIVATE|BEGIN EC PRIVATE)'; then
    echo "[pre-commit] private key content detected in staged diff" >&2; exit 1
  fi
  while IFS= read -r f; do
    [[ -z "$f" || ! -f "$f" ]] && continue
    size=$(wc -c <"$f" 2>/dev/null || echo 0)
    if (( size > 512000 )); then
      echo "[pre-commit] $f is $((size/1024))kb (>500kb)" >&2; exit 1
    fi
  done <<< "$all_staged"
fi

exit 0
