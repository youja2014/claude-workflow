# Shared env (loaded by both apps if needed)
# NOTE: Do not set NODE_ENV here. Docker images set NODE_ENV=production via
# their Dockerfile; setting it here would let env_file override that. For
# local dev outside Docker (yarn nx serve), NODE_ENV defaults to non-production
# which is what dev tooling expects.

# api
API_PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/__project_kebab__

# web
VITE_API_BASE_URL=http://localhost:3000
